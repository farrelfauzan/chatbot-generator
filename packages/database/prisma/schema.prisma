generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

// ─── Core ────────────────────────────────────────────

model Admin {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  role         String    @default("admin")
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime? @db.Timestamptz
  createdAt    DateTime  @default(now()) @db.Timestamptz
  updatedAt    DateTime  @updatedAt @db.Timestamptz
}

model CompanyInfo {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz
}

model Customer {
  id                String              @id @default(cuid())
  phoneNumber       String              @unique
  name              String?
  nickname          String?
  email             String?
  notes             String?
  location          String?             // City for prayer times
  timezone          String              @default("Asia/Jakarta")
  onboardingDone    Boolean             @default(false)
  createdAt         DateTime            @default(now()) @db.Timestamptz
  updatedAt         DateTime            @updatedAt @db.Timestamptz
  conversations     Conversation[]
  memos             Memo[]
  prayerReminder    PrayerReminder?
  scheduledMessages ScheduledMessage[]
}

model Conversation {
  id               String    @id @default(cuid())
  customerId       String
  status           String    @default("active")
  stage            String    @default("greeting")
  mode             String    @default("bot")      // "bot" | "agent"
  lastInboundAt    DateTime? @db.Timestamptz
  lastOutboundAt   DateTime? @db.Timestamptz
  assignedAdminId  String?
  closedAt         DateTime? @db.Timestamptz
  closeReason      String?
  escalatedAt      DateTime? @db.Timestamptz
  escalationReason String?
  createdAt        DateTime  @default(now()) @db.Timestamptz
  updatedAt        DateTime  @updatedAt @db.Timestamptz
  customer         Customer  @relation(fields: [customerId], references: [id])
  messages         Message[]
}

model Message {
  id               String       @id @default(cuid())
  conversationId   String
  direction        MessageFlow
  content          String
  messageType      String       @default("text")
  senderType       String       @default("bot")    // "bot" | "agent" | "customer"
  rawPayload       Json?
  gatewayMessageId String?
  createdAt        DateTime     @default(now()) @db.Timestamptz
  conversation     Conversation @relation(fields: [conversationId], references: [id])
}

// ─── AI & Knowledge ──────────────────────────────────

model FaqEntry {
  id        String                          @id @default(cuid())
  question  String
  answer    String
  category  String?
  isActive  Boolean                         @default(true)
  embedding Unsupported("vector(1536)")?
}

model LlmLog {
  id              String   @id @default(cuid())
  conversationId  String?
  messageId       String?
  model           String
  promptSummary   String
  responseSummary String
  createdAt       DateTime @default(now()) @db.Timestamptz
}

model PromptTemplate {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  category    String
  content     String
  variables   Json     @default("[]")
  isActive    Boolean  @default(true)
  version     Int      @default(1)
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz

  @@index([category])
}

model BotConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz
}

model KnowledgeChunk {
  id         String                          @id @default(cuid())
  sourceType String                           // "faq" | "pricing" | "bot_behavior" | "policy" | "custom"
  sourceId   String?                          // FK to original record if applicable
  title      String
  content    String                           // The text chunk
  metadata   Json?
  embedding  Unsupported("vector(1536)")?
  isActive   Boolean                         @default(true)
  createdAt  DateTime                        @default(now()) @db.Timestamptz
  updatedAt  DateTime                        @updatedAt @db.Timestamptz

  @@index([sourceType])
}

// ─── Wulan AI Models ─────────────────────────────────

model Memo {
  id         String                       @id @default(cuid())
  customerId String
  content    String
  title      String?
  tags       String[]
  embedding  Unsupported("vector(1536)")?
  reminderAt DateTime?                    @db.Timestamptz
  reminded   Boolean                      @default(false)
  createdAt  DateTime                     @default(now()) @db.Timestamptz
  updatedAt  DateTime                     @updatedAt @db.Timestamptz
  customer   Customer                     @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@map("memos")
}

model PrayerReminder {
  id         String   @id @default(cuid())
  customerId String   @unique
  location   String
  timezone   String   @default("Asia/Jakarta")
  prayers    String[] @default(["Fajr", "Dhuhr", "Asr", "Maghrib", "Isha"]) // which prayers to remind
  isActive   Boolean  @default(true)
  lastSentKey String?  // dedup: "Fajr:04:35" prevents duplicate sends
  createdAt  DateTime @default(now()) @db.Timestamptz
  updatedAt  DateTime @updatedAt @db.Timestamptz
  customer   Customer @relation(fields: [customerId], references: [id])

  @@map("prayer_reminders")
}

model ScheduledMessage {
  id             String    @id @default(cuid())
  customerId     String
  targetPhone    String
  targetName     String?
  content        String
  scheduledAt    DateTime  @db.Timestamptz
  sentAt         DateTime? @db.Timestamptz
  status         String    @default("pending") // pending | sent | failed | cancelled
  repeatInterval String?   // null = one-time, "daily" | "weekly" | "monthly" | custom cron
  createdAt      DateTime  @default(now()) @db.Timestamptz
  updatedAt      DateTime  @updatedAt @db.Timestamptz
  customer       Customer  @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@index([status, scheduledAt])
  @@map("scheduled_messages")
}

model DailyQuote {
  id        String   @id @default(cuid())
  content   String
  source    String?
  category  String   @default("islamic") // islamic | motivational | productivity
  createdAt DateTime @default(now()) @db.Timestamptz

  @@map("daily_quotes")
}

// ─── Enums ───────────────────────────────────────────

enum MessageFlow {
  inbound
  outbound
}
