generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

// ─── Core ────────────────────────────────────────────

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("admin")
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CompanyInfo {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id            String         @id @default(cuid())
  phoneNumber   String         @unique
  name          String?
  email         String?
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  conversations Conversation[]
  orders        Order[]
  files         CustomerFile[]
}

model Conversation {
  id               String    @id @default(cuid())
  customerId       String
  status           String    @default("active")
  stage            String    @default("greeting")
  mode             String    @default("bot")      // "bot" | "agent"
  lastInboundAt    DateTime?
  lastOutboundAt   DateTime?
  assignedAdminId  String?
  closedAt         DateTime?
  closeReason      String?
  escalatedAt      DateTime?
  escalationReason String?
  cartSnapshot     Json?                           // Cart items saved on session expiry
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  customer         Customer  @relation(fields: [customerId], references: [id])
  messages         Message[]
  files            CustomerFile[]
}

model Message {
  id               String       @id @default(cuid())
  conversationId   String
  direction        MessageFlow
  content          String
  messageType      String       @default("text")
  senderType       String       @default("bot")    // "bot" | "agent" | "customer"
  rawPayload       Json?
  gatewayMessageId String?
  createdAt        DateTime     @default(now())
  conversation     Conversation @relation(fields: [conversationId], references: [id])
}

// ─── Catalog ─────────────────────────────────────────

model CatalogImage {
  id          String   @id @default(cuid())
  title       String
  description String?
  imageUrl    String                             // S3 URL
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Commerce ────────────────────────────────────────

model Order {
  id                String      @id @default(cuid())
  orderNumber       String      @unique
  customerId        String
  conversationId    String?
  status            String      @default("draft")
  recipientName     String?
  recipientPhone    String?
  recipientAddress  String?
  subtotal          Decimal     @db.Decimal(12, 2)
  discountAmount    Decimal     @default(0) @db.Decimal(12, 2)
  shippingAmount    Decimal     @default(0) @db.Decimal(12, 2)
  taxAmount         Decimal     @default(0) @db.Decimal(12, 2)
  totalAmount       Decimal     @db.Decimal(12, 2)
  sablonSides       Int         @default(0)
  sablonTotal       Decimal     @default(0) @db.Decimal(12, 2)
  paymentLink       String?
  paymentGatewayId  String?
  paymentStatus     String?                    // "pending" | "paid" | "failed" | "expired"
  paidAt            DateTime?
  notes             String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  customer          Customer    @relation(fields: [customerId], references: [id])
  items             OrderItem[]
  files             CustomerFile[]
}

model OrderItem {
  id                  String            @id @default(cuid())
  orderId             String
  productNameSnapshot String
  quantity            Int
  unitPrice           Decimal           @db.Decimal(12, 2)
  lineTotal           Decimal           @db.Decimal(12, 2)
  // Custom box specs (for formula-based pricing)
  boxType             String?           // "dus_baru" | "dus_pizza"
  material            String?           // "singlewall" | "cflute" | "doublewall"
  panjang             Float?
  lebar               Float?
  tinggi              Float?
  order               Order             @relation(fields: [orderId], references: [id])
}

// ─── AI & Knowledge ──────────────────────────────────

model FaqEntry {
  id        String                          @id @default(cuid())
  question  String
  answer    String
  category  String?
  isActive  Boolean                         @default(true)
  embedding Unsupported("vector(1536)")?
}

model LlmLog {
  id              String   @id @default(cuid())
  conversationId  String?
  messageId       String?
  model           String
  promptSummary   String
  responseSummary String
  createdAt       DateTime @default(now())
}

model PromptTemplate {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  category    String
  content     String
  variables   Json     @default("[]")
  isActive    Boolean  @default(true)
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
}

model BotConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model KnowledgeChunk {
  id         String                          @id @default(cuid())
  sourceType String                           // "faq" | "pricing" | "bot_behavior" | "policy" | "custom"
  sourceId   String?                          // FK to original record if applicable
  title      String
  content    String                           // The text chunk
  metadata   Json?
  embedding  Unsupported("vector(1536)")?
  isActive   Boolean                         @default(true)
  createdAt  DateTime                        @default(now())
  updatedAt  DateTime                        @updatedAt

  @@index([sourceType])
}

// ─── Customer Files ──────────────────────────────────

model CustomerFile {
  id             String       @id @default(cuid())
  customerId     String
  conversationId String
  orderId        String?
  fileType       String       @default("design")  // "design" | "reference" | "complaint_photo"
  originalName   String
  mimeType       String
  s3Key          String
  s3Url          String
  fileSize       Int?
  createdAt      DateTime     @default(now())
  customer       Customer     @relation(fields: [customerId], references: [id])
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  order          Order?       @relation(fields: [orderId], references: [id])

  @@index([conversationId])
  @@index([orderId])
}

// ─── Enums ───────────────────────────────────────────

enum MessageFlow {
  inbound
  outbound
}

// ─── CS Phones ───────────────────────────────────────

model CsPhone {
  id          String   @id @default(cuid())
  phone       String   @unique
  name        String
  isActive    Boolean  @default(true)
  loadCount   Int      @default(0)
  lastEscalatedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
