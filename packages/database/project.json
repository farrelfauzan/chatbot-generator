{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "database",
  "projectType": "library",
  "sourceRoot": "packages/database",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/database",
        "command": "pnpm build"
      }
    },
    "generate": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/database",
        "command": "pnpm prisma:generate"
      }
    }
  },
  "tags": ["scope:shared", "type:data"]
}
